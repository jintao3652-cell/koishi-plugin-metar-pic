    // зјҲжҳҸзҳ§жөңжҲқзң°
    const cloudDescriptions = parsedMETAR.clouds.map(cloud => {
      const cloudDesc = config.cloudCoverageMap.find(item => item.code === cloud.type)?.description || cloud.type;
      return `${cloudDesc} ${cloud.height}й‘»еҚһжҳӮ`;
    });
    const cloudText = cloudDescriptions.length > 0 ? `жөңжҲҰеҷәй”ӣ?{cloudDescriptions.join('й”„1Ө7?)}` : 'йҸғзҠіжЁүй’ҒжӨҫз°ҜзҒ„1Ө7?;

    // зјҲжҳҸзҳ§жҫ¶в•ӮзҡөйҗңжӢҢи–„1Ө7
    const weatherDescriptions = parsedMETAR.weather.map(code => {
      return config.weatherMap.find(item => item.code === code)?.description || code;
    });
    const weatherText = weatherDescriptions.length > 0 ? `жҫ¶в•ӮзҡөйҗңжӢҢи–„й”„1Ө7?{weatherDescriptions.join('й”„1Ө7?)}` : '';

    return `
    жӨӢеәЎжӮ„1Ө7 ${windText}йҠ„1Ө7?    й‘іеўгҹоқҶжҗ„1Ө7?${parsedMETAR.visibility} з»«зӮҪвӮ„1Ө7?    ${cloudText}йҠ„1Ө7?    ${weatherText}
    еЁ“в•Ғе®ійҚңеІ„о—“зҖөжҺ“еҜҡйҸҒйўҒиҙҹ ${parsedMETAR.temperature} жҺіCйҠ„1Ө7?    й—ҮиҢ¬еҒЈеЁ“в•Ғе®іж¶„1Ө7?${parsedMETAR.dewpoint} жҺіCй”ӣеІҖжөүзўгөи§„з®Қжҗҙпёҝиҙҹ ${humidity}%йҠ„1Ө7?    еЁҙеі°й’©й—ҲгҲЎзҡөйҚҳе¬©иҙ„1Ө7 ${parsedMETAR.pressure} ${parsedMETAR.pressureUnit}йҠ„1Ө7?  `.replace(/\s+/g, ' ').trim();
  }

  // йҗўзҶёеһҡйҗңйўҒе”¬йҚ–ж «ж®‘жөңжҲқзң°ж·Үв„ғдј„1Ө7 - жөЈи·Ёж•ӨйҸ„зҠІзҡ зҗӣг„§зӮ•з’Ү?  function generateModernCloudInfo(clouds: any[], config: Config): string {
    if (clouds.length === 0) {
      const noCloudDescription = config.cloudCoverageMap.find(item => item.code === 'NSC')?.description || 'йҸғзҠіжЁүй’ҒжӨҫз°ҜзҒ„1Ө7?;
      return `
      <div class="cloud-section">
        <h2>жөңжҲқзң„1Ө7</h2>
        <table class="data-table">
            <tr>
                <td>${noCloudDescription}</td>
                <td>NSC</td>
                <td>${noCloudDescription}</td>
            </tr>
        </table>
      </div>`;
    }
    
    return `
    <div class="cloud-section">
        <h2>жөңжҲқзң„1Ө7</h2>
        <table class="data-table">
            ${clouds.map(cloud => {
              const description = config.cloudCoverageMap.find(item => item.code === cloud.type)?.description || cloud.type;
              return `
                <tr>
                    <td>${cloud.height} ft</td>
                    <td>${cloud.type}</td>
                    <td>${description}</td>
                </tr>
              `;
            }).join('')}
        </table>
    </div>`;
  }

  // йҗўзҶёеһҡйҗңйўҒе”¬йҚ–ж «ж®‘з’әжҲҰдәҫзҗӣг„Ұзү„1Ө7
  function generateModernRunwayTable(runwayWindComponents: any[]): string {
    if (runwayWindComponents.length === 0) return '';
    
    return `
    <div class="runway-section">
        <h2>з’әжҲҰдә„1Ө7</h2>
        <div style="overflow-x: auto;">
            <table class="data-table">
                <tr>
                    <td><strong>зјӮж §еҪ„1Ө7</strong></td>
                    <td><strong>й‘ёоҒ„жӮ„1Ө7</strong></td>
                    <td><strong>жёҡСҮо—“</strong></td>
                    <td><strong>жӨӨе •о—„1Ө7</strong></td>
                    <td><strong>жёҡСҮо—“йҗ§жғ§еһҺе§Ј?/strong></td>
                </tr>
                ${runwayWindComponents.map(item => {
                  const runway = item.runway;
                  const components = item.components;
                  const crosswindPercent = Math.round((components.crosswind / (parseInt(components.headwind) || 1)) * 100);
                  
                  return `
                    <tr>
                        <td><strong>${runway.leIdent}/${runway.heIdent}</strong></td>
                        <td>${runway.leHeadingDegt}жҺ„1Ө7-${runway.heHeadingDegt}жҺ„1Ө7</td>
                        <td>${components.crosswind.toFixed(1)} kt</td>
                        <td>${components.headwind.toFixed(1)} kt</td>
                        <td>${crosswindPercent}%</td>
                    </tr>
                  `;
                }).join('')}
            </table>
        </div>
        <p class="help-text">йҺёеӨҗвӮ¬е—ӣо—“йҚ’е—ӣеҷәйҺәжҺ‘з°ӯй”ӣеұҫжё¶жҫ¶СҮгўгҠжӨӢеәЎеһҺй–Іеҝ•ж®‘з’әжҲҰдәҫе®ёжҹҘзҸ®жөңоҶҪжЁүз»ўгзҢҙзҙқйҗўг„Өз°¬жёҡСҮо—“з’Ғпј„з•»йҠ„1Ө7?/p>
    </div>`;
  }

  // й‘ҫеі°еҪҮжҫ¶в•ӮзҡөйҺ»еҝҡе „1Ө7 - жөЈи·Ёж•ӨйҸ„зҠІзҡ зҗӣг„§зӮ•з’Ү?  function getWeatherDescription(weather: string[], config: Config): string {
    if (weather.length === 0) return 'йҸ…еӯҳж№„1Ө7';
    const descriptions = weather.map(code => {
      const found = config.weatherMap.find(item => item.code === code);
      return found ? found.description : code;
    });
    return descriptions.join('й”„1Ө7?) || 'жҫ¶в•Ӯзҡөй‘№оҲҡгӮҪ';
  }

  // й‘ҫеі°еҪҮз’Җп№ўгжҶЎж·Үв„ғдј… - жөЈи·Ёж•ӨйҸ„зҠІзҡ зҗӣг„§зӮ•з’Ү?  function getWarnings(parsedMETAR: ParsedMETAR, config: Config): string {
    const warningWeather = parsedMETAR.weather.filter(w => {
      const description = config.weatherMap.find(item => item.code === w)?.description || '';
      return description.includes('й—Ҷй”ӢжҜ„1Ө7') || description.includes('жӨӢеәўжҜ„1Ө7') || description.includes('жӨӢжҲ еҡ„1Ө7');
    });
    
    if (warningWeather.length > 0) {
      const warningDescriptions = warningWeather.map(code => {
        return config.weatherMap.find(item => item.code === code)?.description || code;
      });
      return `йҸҲеӨҠгҒүе§ҳж—Үо„ҹйҚ„1Ө7? ${warningDescriptions.join(', ')}`;
    }
    return 'йҸғзҠәо„ҹйҚӣ?;
  }

  // жқҲе‘ӯе§ӘйҚ‘иҠҘжҡҹ
  function calculateHumidity(temp: number, dewpoint: number): string {
    if (isNaN(temp) || isNaN(dewpoint)) return 'N/A';
    const rh = 100 * (Math.exp((17.625 * dewpoint) / (243.04 + dewpoint)) / 
                      Math.exp((17.625 * temp) / (243.04 + temp)));
    return Math.round(rh).toString();
  }

  function getFIRRegion(icao: string): string {
    if (icao.startsWith('ZL')) return 'йҚҸжқҝзӘһйҺҜе‘®е§ӨйҚ„1Ө7?;
    if (icao.startsWith('ZG')) return 'йӘһеһ®зӘһйҺҜе‘®е§ӨйҚ„1Ө7?;
    if (icao.startsWith('ZS')) return 'ж¶“е©ғжҚЈйҺҜе‘®е§ӨйҚ„1Ө7?;
    return 'Unknown';
  }
  

  function getTimeAgo(observationTime: string): string {
    if (!observationTime) return 'йҸҲоҒҶз…„1Ө7';
    return 'йҚ’ж°¬еһ„1Ө7';
  }

  function getCeiling(clouds: any[]): string {
    const ceilingCloud = clouds.find(c => c.type === 'BKN' || c.type === 'OVC');
    return ceilingCloud ? ceilingCloud.height : 'None';
  }
}
