  // з’әжҲҰдәҫSVGйҗўзҶёеһҡйҚ‘иҠҘжҡҹ
  function generateRunaySVG(leIdent: string, heIdent: string): string {
    // з’әжҲҰдәҫзҒҸе“„оҮӯйҚҷеӮӣжҡ„1Ө7
    const runwayLength = 480; // з’әжҲҰдәҫй—Җеһ®е®ій”ӣе қзҖӯйҗ©еӯҳжҹҹйҚҡжҲҜзҙ„1Ө7
    const runwayWidth = 65;   // з’әжҲҰдәҫзўг№и—үе®ій”ӣе ҹжҢүйӘһиҷ«жҹҹйҚҡжҲҜзҙҡ
    const centerLineWidth = 4; // ж¶“о…һзёҫз»ҫеһ®оҶ”жҗ„1Ө7?    const centerLineLength = 10; // ж¶“о…һзёҫз»ҫжҢҺзҳЎеЁҲз”ёжҡұжҗҙ?    const centerLineGap = 8; // ж¶“о…һзёҫз»ҫеқ—жЈҝй—„1Ө7?    const thresholdLineWidth = 6; // з’әжҲҰдәҫйҚҸгғҘеҪӣз»ҫеһ®оҶ”жҗҙпёјзҙҷз»”ж «еҡҺй”ӣ?    const thresholdLineLength = 20; // з’әжҲҰдәҫйҚҸгғҘеҪӣз»ҫеқ—жҡұжҗҙ?    const thresholdLineSpacing = 8; // з’әжҲҰдәҫйҚҸгғҘеҪӣз»ҫеқ—жЈҝз’ә?    const fontSize = 16; // з’әжҲҰдәҫзјӮж §еҪҝзҖӣжӨҫз¶Ӣжҫ¶Сғзҡ„1Ө7
    
    // SVGзҒҸе“„оҮ„1Ө7
    const svgWidth = 230;
    const svgHeight = 530;
    
    // з’Ғпј„з•»зҒһе‘¬и…‘жөЈе¶Үз–„1Ө7
    const centerX = svgWidth / 2 - 55;
    const centerY = svgHeight / 2;
    const runwayStartY = centerY - runwayLength / 2;
    const runwayEndY = centerY + runwayLength / 2;
    const runwayStartX = centerX - runwayWidth / 2 ;
    const runwayEndX = centerX + runwayWidth / 2 ;
    
    return `
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${svgWidth} ${svgHeight}" width="${svgWidth}" height="${svgHeight}">
          <!-- з’әжҲҰдәҫж¶“и®із¶Ӣ -->
          <rect x="${runwayStartX}" y="${runwayStartY}" 
                width="${runwayWidth}" height="${runwayLength}" 
                fill="#2a6da1" stroke="#fff" stroke-width="1"/>
          
          <!-- з’әжҲҰдәҫж¶“о…һзёҫз»„1Ө7?-->
          ${generateCenterLine(centerX, runwayStartY, runwayEndY -35, centerLineWidth, centerLineLength, centerLineGap)}
          
          <!-- з’әжҲҰдәҫйҚҸгғҘеҪӣйҸҚеӣ§з№”з»ҫ?- жӨӨе •е„ҙй”ӣе ўзҸ«з»ҫеҢЎзҙ„1Ө7 -->
          ${generateThresholdLines(runwayStartX, runwayStartY, runwayWidth, thresholdLineWidth, thresholdLineLength, thresholdLineSpacing)}
          
          <!-- з’әжҲҰдәҫйҚҸгғҘеҪӣйҸҚеӣ§з№”з»ҫ?- жҗҙжӣўе„ҙй”ӣе ўзҸ«з»ҫеҢЎзҙ„1Ө7 -->
          ${generateThresholdLines(runwayStartX, runwayEndY - thresholdLineLength, runwayWidth, thresholdLineWidth, thresholdLineLength, thresholdLineSpacing)}
          
          <!-- з’әжҲҰдәҫзјӮж §еҪҝ - жӨӨе •е„ҙй”ӣе қж№ӘйҚҸгғҘеҪӣз»ҫеӨёз¬ӮйҸӮзҷёзҙ„1Ө7 -->
          <text x="${centerX}" y="${runwayStartY + 35}" 
                text-anchor="middle" dominant-baseline="middle"
                font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
                font-size="${fontSize}" font-weight="600" fill="#fff">
              ${leIdent}
          </text>
          
          <!-- з’әжҲҰдәҫзјӮж §еҪҝ - жҗҙжӣўе„ҙй”ӣе қж№ӘйҚҸгғҘеҪӣз»ҫеӨёз¬ӮйҸӮзҷёзҙ„1Ө7 -->
          <text x="${centerX}" y="${runwayEndY - 35}" 
                text-anchor="middle" dominant-baseline="middle"
                font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
                font-size="${fontSize}" font-weight="600" fill="#fff">
              ${heIdent}
          </text>
      </svg>`;
  }

  // йҗўзҶёеһҡз’әжҲҰдәҫж¶“о…һзёҫз»ҫ?  function generateCenterLine(centerX: number, startY: number, endY: number, lineWidth: number, lineLength: number, gap: number): string {
    let lines = '';
    let y = startY + gap + 35;
    
    while (y + lineLength < endY) {
      lines += `<rect x="${centerX - lineWidth / 2}" y="${y}" 
                     width="${lineWidth}" height="${lineLength}" fill="#fff"/>`;
      y += lineLength + gap;
    }
    
    return lines;
  }

  // йҗўзҶёеһҡз’әжҲҰдәҫйҚҸгғҘеҪӣйҸҚеӣ§з№”з»ҫеҢЎзҙҷз»”ж «еҡҺй”„1Ө7?  function generateThresholdLines(startX: number, y: number, runwayWidth: number, lineWidth: number, lineLength: number, spacing: number): string {
    let lines = '';
    const lineCount = Math.floor(runwayWidth / (lineWidth + spacing));
    const totalWidth = (lineWidth * lineCount) + (spacing * (lineCount - 1));
    const startLineX = startX + (runwayWidth - totalWidth) / 2;
    
    for (let i = 0; i < lineCount; i++) {
      const x = startLineX + i * (lineWidth + spacing);
      lines += `<rect x="${x}" y="${y}" 
                     width="${lineWidth}" height="${lineLength}" fill="#fff"/>`;
    }
    
    return lines;
  }

