                        <!-- й‘іеұҫж«ҷйҚҰе——жӢ°йҚ’иҜІе®„1Ө7 -->
                        <circle cx="150" cy="150" r="145" fill="#2a6da1" stroke="#ffffff" stroke-width="2" opacity="0.8"/>
                        <circle cx="150" cy="150" r="125" fill="#f7fafc" stroke="#e2e8f0" stroke-width="1" style="fill:url(#compass_bg)"/>
                        ${windCompassBackground ?? ''}
                        
                        <!-- йҸӮз‘°жӮңйҚ’иҜІе®і -->
                        ${windCompassBackground ? '' : generateDirectionTicks()}
                        
                        <!-- з’әжҲҰдәҫз»ҫжҢҺжҪҜ - жөЈи·Ёж•Өж¶“е·–unway-selectorйҗ©зЁҝжӮ“йҗЁеӢ¬зүёеҜ„1Ө7?-->
